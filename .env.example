# Example environment configuration
# Copy this file to .env in each service directory and adjust values as needed

# PostgreSQL
DB_URL=postgres://admin:admin@localhost:5432/orders_db

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672/

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Service Ports
GRPC_PORT=50051  # Order Service
# GRPC_PORT=50052  # Stock Service
# HTTP_PORT=8080   # Analytics Service

# Stock Service Address (for Order Service)
STOCK_SERVICE_ADDR=localhost:50052
